<Window x:Class="TimeClock.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeClock Client"
        Height="500" Width="900"
        MinHeight="400" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid SnapsToDevicePixels="True" Background="#FF0F172A">
        <!-- Sfondo gradient "dashboard" -->

        <!-- Ombra dietro il pannello principale -->
        <Border Margin="20,15"
                CornerRadius="20"
                Background="#40FFFFFF"
                Effect="{DynamicResource DropShadow}">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock Text="TimeClock"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Client di timbratura."
                                   FontSize="11"
                                   Foreground="#CCFFFFFF"/>
                    </StackPanel>

                    <!-- Pulsanti finestra -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="_"
                                Width="26" Height="22"
                                Margin="3,0"
                                Click="Minimize_Click"
                                Background="#20FFFFFF"
                                BorderBrush="#40FFFFFF"
                                Foreground="White"
                                FontWeight="Bold"
                                MinWidth="26"/>
                        <Button Content="X"
                                Width="26" Height="22"
                                Margin="3,0"
                                Click="Close_Click"
                                Background="#40FF4B4B"
                                BorderBrush="#80FF4B4B"
                                Foreground="White"
                                FontWeight="Bold"
                                MinWidth="26"/>
                    </StackPanel>
                </DockPanel>

                <!-- CONTENUTO PRINCIPALE -->
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" MinWidth="250"/>
                        <ColumnDefinition Width="2*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- PANNELLO SINISTRO: selezione utente + tastierino -->
                    <ScrollViewer Grid.Column="0"
                                  Margin="0,0,10,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Border CornerRadius="15"
                                Background="#60FFFFFF"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Utente"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#DD111827"
                                           Margin="0,0,0,5"/>
                                
                                <ComboBox Grid.Row="1"
                                          x:Name="UserComboBox"
                                          Margin="0,0,0,10"
                                          MinWidth="180"
                                          Background="#10FFFFFF"
                                          BorderBrush="#40FFFFFF"
                                          BorderThickness="1"
                                          Foreground="#DD111827"
                                          SelectionChanged="UserComboBox_SelectionChanged"/>

                                <Border Grid.Row="2"
                                        CornerRadius="8"
                                        Background="#30FFFFFF"
                                        Padding="8"
                                        Margin="0,0,0,8">
                                    <TextBlock x:Name="NumericFilterTextBlock"
                                               Text="Filtro numerico: -"
                                               FontSize="11"
                                               Foreground="#DD111827"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <UniformGrid Grid.Row="3" 
                                            Rows="4" 
                                            Columns="3" 
                                            Margin="0,5,0,5"
                                            VerticalAlignment="Stretch">
                                    <Button Content="1" Margin="1" Click="NumericKey_Click" Tag="1" MinWidth="40" MinHeight="35"/>
                                    <Button Content="2" Margin="1" Click="NumericKey_Click" Tag="2" MinWidth="40" MinHeight="35"/>
                                    <Button Content="3" Margin="1" Click="NumericKey_Click" Tag="3" MinWidth="40" MinHeight="35"/>
                                    <Button Content="4" Margin="1" Click="NumericKey_Click" Tag="4" MinWidth="40" MinHeight="35"/>
                                    <Button Content="5" Margin="1" Click="NumericKey_Click" Tag="5" MinWidth="40" MinHeight="35"/>
                                    <Button Content="6" Margin="1" Click="NumericKey_Click" Tag="6" MinWidth="40" MinHeight="35"/>
                                    <Button Content="7" Margin="1" Click="NumericKey_Click" Tag="7" MinWidth="40" MinHeight="35"/>
                                    <Button Content="8" Margin="1" Click="NumericKey_Click" Tag="8" MinWidth="40" MinHeight="35"/>
                                    <Button Content="9" Margin="1" Click="NumericKey_Click" Tag="9" MinWidth="40" MinHeight="35"/>
                                    <Button Content="C" Margin="1" Click="NumericClear_Click" MinWidth="40" MinHeight="35"/>
                                    <Button Content="0" Margin="1" Click="NumericKey_Click" Tag="0" MinWidth="40" MinHeight="35"/>
                                    <Button Content="⌫" Margin="1" Click="NumericBackspace_Click" MinWidth="40" MinHeight="35"/>
                                </UniformGrid>
                                
                                <Button Grid.Row="4"
                                        Content="⚙ Seleziona cartella"
                                        ToolTip="Seleziona cartella condivisa"
                                        Click="SelectCsvFolder_Click"
                                        Background="#20FFFFFF"
                                        BorderBrush="#50FFFFFF"
                                        Foreground="#DD111827"
                                        FontSize="12"
                                        Margin="0,10,0,0"
                                        Padding="8,4"
                                        HorizontalAlignment="Stretch"
                                        MinHeight="30"/>
                            </Grid>
                        </Border>
                    </ScrollViewer>

                    <!-- PANNELLO DESTRO: pulsantoni e info -->
                    <Border Grid.Column="1"
                            CornerRadius="15"
                            Background="#50FFFFFF"
                            Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Pulsanti Entrata/Uscita -->
                            <StackPanel Grid.Row="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="Timbratura"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#DD111827"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>
                                
                                <StackPanel x:Name="ButtonStack"
                                            Orientation="Horizontal" 
                                            HorizontalAlignment="Center">
                                    <Button x:Name="EntrataButton"
                                            Content="Entrata"
                                            Width="160" Height="60"
                                            Margin="5,0"
                                            Click="EntrataButton_Click"
                                            IsEnabled="False"
                                            Background="#2010B981"
                                            Foreground="White"
                                            FontSize="16"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            MinWidth="120"
                                            MinHeight="50"/>
                                            
                                    <Button x:Name="UscitaButton"
                                            Content="Uscita"
                                            Width="160" Height="60"
                                            Margin="5,0"
                                            Click="UscitaButton_Click"
                                            IsEnabled="False"
                                            Background="#20EF4444"
                                            Foreground="White"
                                            FontSize="16"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            MinWidth="120"
                                            MinHeight="50"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Info in basso -->
                            <Border Grid.Row="1"
                                    CornerRadius="8"
                                    Background="#20FFFFFF"
                                    Padding="8"
                                    Margin="0,15,0,0">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="Ultima azione:"
                                               FontSize="11"
                                               Foreground="#AA111827"/>
                                    <TextBlock x:Name="LastActionTextBlock"
                                               Text="{Binding LastActionText}"
                                               FontSize="11"
                                               Foreground="#DD111827"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"/>
                                </StackPanel>
                            </Border>

                            <!-- Riquadro Riepilogo Ore Mensili (nuova aggiunta) -->
                            <Border Grid.Row="2"
                                    Margin="0,15,0,0"
                                    Background="#20111827"
                                    CornerRadius="8"
                                    Padding="15"
                                    Visibility="{Binding ShowSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Riepilogo Ore Mese Corrente"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#DD111827"
                                               Margin="0,0,0,10"
                                               HorizontalAlignment="Center"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Text="Ordinarie" FontSize="11" Foreground="#AA111827" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding MonthlyOrdinaryHours}" FontSize="16" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="Extra" FontSize="11" Foreground="#AA111827" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding MonthlyExtraHours}" FontSize="16" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>

    <!-- Risorsa per l'ombra -->
    <Window.Resources>
        <DropShadowEffect x:Key="DropShadow"
                          Color="#000000"
                          Opacity="0.4"
                          BlurRadius="25"
                          ShadowDepth="4"/>
    </Window.Resources>
</Window>
