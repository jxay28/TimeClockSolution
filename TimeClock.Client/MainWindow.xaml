<Window x:Class="TimeClock.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeClock Client"
        Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid SnapsToDevicePixels="True" Background="#FF0F172A">
        <!-- Sfondo gradient "dashboard" -->

        <!-- Ombra dietro il pannello principale -->
        <Border Margin="30"
                CornerRadius="25"
                Background="#40FFFFFF"
                Effect="{DynamicResource DropShadow}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <DockPanel Grid.Row="0">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock Text="TimeClock"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Client di timbratura."
                                   FontSize="12"
                                   Foreground="#CCFFFFFF"/>
                    </StackPanel>

                    <!-- Pulsanti finestra -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="_"
                                Width="28" Height="24"
                                Margin="4,0"
                                Click="Minimize_Click"
                                Background="#20FFFFFF"
                                BorderBrush="#40FFFFFF"
                                Foreground="White"
                                FontWeight="Bold"/>
                        <Button Content="X"
                                Width="28" Height="24"
                                Margin="4,0"
                                Click="Close_Click"
                                Background="#40FF4B4B"
                                BorderBrush="#80FF4B4B"
                                Foreground="White"
                                FontWeight="Bold"/>
                    </StackPanel>
                </DockPanel>

                <!-- CONTENUTO PRINCIPALE -->
                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PANNELLO SINISTRO: selezione utente + tastierino -->
                    <Border Grid.Column="0"
                            Margin="0,0,15,0"
                            CornerRadius="20"
                            Background="#60FFFFFF">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Utente"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#DD111827"/>
                            <ComboBox Grid.Row="1"
                                      x:Name="UserComboBox"
                                      Margin="0,8,0,12"
                                      MinWidth="200"
                                      Background="#10FFFFFF"
                                      BorderBrush="#40FFFFFF"
                                      BorderThickness="1"
                                      Foreground="#DD111827"
                                      SelectionChanged="UserComboBox_SelectionChanged"/>

                            <Border Grid.Row="2"
                                    CornerRadius="10"
                                    Background="#30FFFFFF"
                                    Padding="10"
                                    Margin="0,0,0,10">
                                <TextBlock x:Name="NumericFilterTextBlock"
                                           Text="Filtro numerico: -"
                                           FontSize="12"
                                           Foreground="#DD111827"/>
                            </Border>

                            <UniformGrid Grid.Row="3" Rows="4" Columns="3" Margin="0,0,0,4" VerticalAlignment="Stretch">
                                <Button Content="1" Margin="2" Click="NumericKey_Click" Tag="1"/>
                                <Button Content="2" Margin="2" Click="NumericKey_Click" Tag="2"/>
                                <Button Content="3" Margin="2" Click="NumericKey_Click" Tag="3"/>
                                <Button Content="4" Margin="2" Click="NumericKey_Click" Tag="4"/>
                                <Button Content="5" Margin="2" Click="NumericKey_Click" Tag="5"/>
                                <Button Content="6" Margin="2" Click="NumericKey_Click" Tag="6"/>
                                <Button Content="7" Margin="2" Click="NumericKey_Click" Tag="7"/>
                                <Button Content="8" Margin="2" Click="NumericKey_Click" Tag="8"/>
                                <Button Content="9" Margin="2" Click="NumericKey_Click" Tag="9"/>
                                <Button Content="C" Margin="2" Click="NumericClear_Click"/>
                                <Button Content="0" Margin="2" Click="NumericKey_Click" Tag="0"/>
                                <Button Content="⌫" Margin="2" Click="NumericBackspace_Click"/>
                            </UniformGrid>

                        </Grid>
                    </Border>

                    <!-- PANNELLO DESTRO: pulsantoni e info -->
                    <Border Grid.Column="1"
                            CornerRadius="20"
                            Background="#50FFFFFF">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Pulsanti Entrata/Uscita -->
                            <StackPanel Grid.Row="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="Timbratura"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#DD111827"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,20"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="EntrataButton"
                                            Content="Entrata"
                                            Width="170" Height="62"
                                            Margin="10,0"
                                            Click="EntrataButton_Click"
                                            IsEnabled="False"
                                            Background="#2010B981"
                                            Foreground="White"
                                            FontSize="18"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            />
                                    <Button x:Name="UscitaButton"
                                            Content="Uscita"
                                            Width="170" Height="62"
                                            Margin="10,0"
                                            Click="UscitaButton_Click"
                                            IsEnabled="False"
                                            Background="#20EF4444"
                                            Foreground="White"
                                            FontSize="18"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            />
                                </StackPanel>
                            </StackPanel>

                            <!-- Info in basso -->
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,20,0,0">
                                <TextBlock Text="Ultima azione: "
                                           FontSize="12"
                                           Foreground="#AA111827"/>
                                <TextBlock x:Name="LastActionTextBlock"
                                           Text="{Binding LastActionText}"
                                           FontSize="12"
                                           Foreground="#DD111827"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Ingranaggio in alto a destra del layout destro -->
                    <Button Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="40"
                            Height="40"
                            Margin="0,10,10,0"
                            Content="⚙"
                            ToolTip="Seleziona cartella condivisa"
                            Click="SelectCsvFolder_Click"
                            Background="#20FFFFFF"
                            BorderBrush="#50FFFFFF"
                            Foreground="#DD111827"
                            FontSize="16"
                            Cursor="Hand"
                            Panel.ZIndex="5"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>

    <!-- Risorsa per l'ombra -->
    <Window.Resources>
        <DropShadowEffect x:Key="DropShadow"
                          Color="#000000"
                          Opacity="0.4"
                          BlurRadius="25"
                          ShadowDepth="4"/>
    </Window.Resources>
</Window>
