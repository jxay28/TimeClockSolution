<Window x:Class="TimeClock.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeClock Client"
        Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Grid SnapsToDevicePixels="True" Background="#FF0F172A">
        <!-- Ombra dietro il pannello principale -->
        <Border Margin="30"
                CornerRadius="25"
                Background="#40FFFFFF"
                Effect="{DynamicResource DropShadow}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <DockPanel Grid.Row="0">
                    <!-- Titolo applicazione -->
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock Text="TimeClock"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Client di timbratura."
                                   FontSize="12"
                                   Foreground="#CCFFFFFF"/>
                    </StackPanel>

                    <!-- Pulsanti finestra -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="_"
                                Width="28" Height="24"
                                Margin="4,0"
                                Click="Minimize_Click"
                                Background="#20FFFFFF"
                                BorderBrush="#40FFFFFF"
                                Foreground="White"
                                FontWeight="Bold"/>
                        <Button Content="X"
                                Width="28" Height="24"
                                Margin="4,0"
                                Click="Close_Click"
                                Background="#40FF4B4B"
                                BorderBrush="#80FF4B4B"
                                Foreground="White"
                                FontWeight="Bold"/>
                    </StackPanel>
                </DockPanel>

                <!-- CONTENUTO PRINCIPALE -->
                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PANNELLO DESTRO: controlli principali -->
                    <Border Grid.ColumnSpan="2"
                            CornerRadius="20"
                            Background="#50FFFFFF">
                        <!-- Avvolge il contenuto in uno ScrollViewer per consentire lo scorrimento -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Sezione utente e tastierino numerico -->
                            <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Top">
                                <TextBlock Text="Utente"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#DD111827"/>
                                <ComboBox x:Name="UserComboBox"
                                          Margin="0,8,0,0"
                                          MinWidth="200"
                                          Background="#10FFFFFF"
                                          BorderBrush="#40FFFFFF"
                                          BorderThickness="1"
                                          Foreground="#DD111827"
                                          SelectionChanged="UserComboBox_SelectionChanged"/>

                                <TextBlock Text="Filtro numerico"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#DD111827"
                                           Margin="0,18,0,0"/>
                                <TextBox x:Name="UserFilterTextBox"
                                         Margin="0,8,0,10"
                                         MinWidth="200"
                                         Padding="6"
                                         Background="#10FFFFFF"
                                         Foreground="#DD111827"
                                         BorderBrush="#40FFFFFF"
                                         BorderThickness="1"
                                         TextChanged="UserFilterTextBox_TextChanged"/>

                                <!-- Tastierino numerico -->
                                <Grid Margin="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Content="1" Tag="1" Grid.Row="0" Grid.Column="0"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>
                                    <Button Content="2" Tag="2" Grid.Row="0" Grid.Column="1"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>
                                    <Button Content="3" Tag="3" Grid.Row="0" Grid.Column="2"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>

                                    <Button Content="4" Tag="4" Grid.Row="1" Grid.Column="0"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>
                                    <Button Content="5" Tag="5" Grid.Row="1" Grid.Column="1"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>
                                    <Button Content="6" Tag="6" Grid.Row="1" Grid.Column="2"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>

                                    <Button Content="7" Tag="7" Grid.Row="2" Grid.Column="0"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>
                                    <Button Content="8" Tag="8" Grid.Row="2" Grid.Column="1"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>
                                    <Button Content="9" Tag="9" Grid.Row="2" Grid.Column="2"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>

                                    <Button Content="0" Tag="0" Grid.Row="3" Grid.Column="0"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadNumber_Click"
                                            Background="#20FFFFFF"
                                            Foreground="#DD111827"
                                            BorderThickness="0"/>
                                    <Button Content="Cancella" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                            Margin="4" Padding="10,6"
                                            Click="KeypadClear_Click"
                                            Background="#20EF4444"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                </Grid>
                            </StackPanel>

                            <!-- Sezione destra: pulsanti Entrata/Uscita e mostrazione timbratura -->
                            <StackPanel Grid.Row="0" Grid.Column="1"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="Timbratura"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#DD111827"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,20"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="EntrataButton"
                                            Content="Entrata"
                                            Width="140" Height="50"
                                            Margin="10,0"
                                            Click="EntrataButton_Click"
                                            IsEnabled="False"
                                            Background="#2010B981"
                                            Foreground="White"
                                            FontSize="16"
                                            BorderThickness="0"
                                            Cursor="Hand"/>
                                    <Button x:Name="UscitaButton"
                                            Content="Uscita"
                                            Width="140" Height="50"
                                            Margin="10,0"
                                            Click="UscitaButton_Click"
                                            IsEnabled="False"
                                            Background="#20EF4444"
                                            Foreground="White"
                                            FontSize="16"
                                            BorderThickness="0"
                                            Cursor="Hand"/>
                                </StackPanel>

                                <Button x:Name="ShowLastTimbraturaButton"
                                        Margin="0,20,0,0"
                                        Padding="10"
                                        Width="280"
                                        Click="ShowLastTimbraturaButton_Click"
                                        Background="#30FFFFFF"
                                        BorderThickness="0"
                                        Foreground="#DD111827"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Content="Mostra ultima timbratura"/>
                            </StackPanel>

                            <!-- Sezione inferiore destra: ultima azione e selezione cartella -->
                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Right"
                                        Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="Ultima azione: "
                                               FontSize="11"
                                               Foreground="#AA111827"/>
                                    <TextBlock x:Name="LastActionTextBlock"
                                               Text="N/A"
                                               FontSize="11"
                                               Foreground="#DD111827"/>
                                </StackPanel>
                                <Button x:Name="SelectSharedFolderButton"
                                        Content="⚙ Scegli cartella"
                                        Margin="0,10,0,6"
                                        Padding="8,6"
                                        Click="SelectCsvFolder_Click"
                                        Background="#2010B981"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                                <TextBlock x:Name="SharedFolderTextBlock"
                                           Text="Nessuna cartella selezionata"
                                           FontSize="11"
                                           Foreground="#BB111827"
                                           TextWrapping="Wrap"
                                           Width="260"/>
                            </StackPanel>
                        </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>

    <!-- Risorsa per l'ombra -->
    <Window.Resources>
        <DropShadowEffect x:Key="DropShadow"
                          Color="#000000"
                          Opacity="0.4"
                          BlurRadius="25"
                          ShadowDepth="4"/>
    </Window.Resources>
</Window>