<Window x:Class="TimeClock.Server.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aggiungi Utente" Height="460" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ID -->
        <Label Content="ID:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="IdBox" Grid.Row="0" Grid.Column="1" Margin="0,2"/>

        <!-- Nome -->
        <Label Content="Nome:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="NomeBox" Grid.Row="1" Grid.Column="1" Margin="0,2"/>

        <!-- Cognome -->
        <Label Content="Cognome:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="CognomeBox" Grid.Row="2" Grid.Column="1" Margin="0,2"/>

        <!-- Ruolo -->
        <Label Content="Ruolo:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="RuoloBox" Grid.Row="3" Grid.Column="1" Margin="0,2"/>

        <!-- Data Assunzione -->
        <Label Content="Data assunzione:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <DatePicker x:Name="AssunzionePicker" Grid.Row="4" Grid.Column="1" Margin="0,2" SelectedDate="{x:Static sys:DateTime.Now}" xmlns:sys="clr-namespace:System;assembly=mscorlib"/>

        <!-- Ore Contratto -->
        <Label Content="Ore settimanali:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="OreBox" Grid.Row="5" Grid.Column="1" Margin="0,2"/>

        <!-- Salario Base -->
        <Label Content="Salario base €/h:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="SalarioBaseBox" Grid.Row="6" Grid.Column="1" Margin="0,2"/>

        <!-- Salario Extra -->
        <Label Content="Salario extra €/h:" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="SalarioExtraBox" Grid.Row="7" Grid.Column="1" Margin="0,2"/>

        <!-- Pulsanti -->
        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Salva" Width="80" Margin="5" Click="Save_Click"/>
            <Button Content="Annulla" Width="80" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>