<Window x:Class="TimeClock.Server.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Aggiungi Utente"
        Height="601"
        Width="500"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="#FF0F172A">

    <Grid Margin="20">
        <!-- CARD CENTRALE "VETRO" -->
        <Border Background="#40FFFFFF"
                CornerRadius="18"
                Padding="20"
                Effect="{DynamicResource DropShadowEffect}" Margin="0,0,0,0
                ">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- titolo -->
                    <RowDefinition Height="Auto"/>
                    <!-- seq -->
                    <RowDefinition Height="Auto"/>
                    <!-- id -->
                    <RowDefinition Height="Auto"/>
                    <!-- nome -->
                    <RowDefinition Height="Auto"/>
                    <!-- cognome -->
                    <RowDefinition Height="Auto"/>
                    <!-- ruolo -->
                    <RowDefinition Height="Auto"/>
                    <!-- data assunzione -->
                    <RowDefinition Height="Auto"/>
                    <!-- ore settimanali -->
                    <RowDefinition Height="Auto"/>
                    <!-- salario base -->
                    <RowDefinition Height="Auto"/>
                    <!-- salario extra -->
                    <RowDefinition Height="Auto"/>
                    <!-- ingresso1 -->
                    <RowDefinition Height="Auto"/>
                    <!-- uscita1 -->
                    <RowDefinition Height="Auto"/>
                    <!-- ingresso2 -->
                    <RowDefinition Height="Auto"/>
                    <!-- uscita2 -->
                    <RowDefinition Height="Auto"/>
                    <!-- pulsanti -->
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- TITOLO -->
                <TextBlock Text="Nuovo Utente"
                           Grid.Row="0" Grid.ColumnSpan="2"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0 0 0 10"
                           HorizontalAlignment="Center"/>

                <!-- Numero sequenziale -->
                <TextBlock Text="Numero sequenziale"
                           Grid.Row="1" Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0 4"/>
                <TextBox x:Name="SeqNumberBox"
                         Grid.Row="1" Grid.Column="1"
                         IsReadOnly="True"
                         Style="{StaticResource GlassTextBox}"
                         Margin="0 4"/>

                <!-- ID -->
                <TextBlock Text="ID"
                           Grid.Row="2" Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0 4"/>
                <TextBox x:Name="IdBox"
                         Grid.Row="2" Grid.Column="1"
                         Style="{StaticResource GlassTextBox}"
                         Margin="0 4"/>

                <!-- Nome -->
                <TextBlock Text="Nome"
                           Grid.Row="3" Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0 4"/>
                <TextBox x:Name="NomeBox"
                         Grid.Row="3" Grid.Column="1"
                         Style="{StaticResource GlassTextBox}"
                         Margin="0 4"/>

                <!-- Cognome -->
                <TextBlock Text="Cognome"
                           Grid.Row="4" Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0 4"/>
                <TextBox x:Name="CognomeBox"
                         Grid.Row="4" Grid.Column="1"
                         Style="{StaticResource GlassTextBox}"
                         Margin="0 4"/>

                <!-- Ruolo -->
                <TextBlock Text="Ruolo"
                           Grid.Row="5" Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0 4"/>
                <TextBox x:Name="RuoloBox"
                         Grid.Row="5" Grid.Column="1"
                         Style="{StaticResource GlassTextBox}"
                         Margin="0 4"/>

                <!-- Data Assunzione -->
                <TextBlock Text="Data assunzione"
                           Grid.Row="6" Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0 4"/>
                <DatePicker x:Name="AssunzionePicker"
                            Grid.Row="6" Grid.Column="1"
                            SelectedDate="{x:Static sys:DateTime.Now}"
                            Style="{StaticResource GlassDatePicker}"
                            Margin="0 4"
                            Foreground="Black"/>

                <!-- Ore settimanali -->
                <TextBlock Text="Ore settimanali"
                           Grid.Row="7" Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0 4"/>
                <TextBox x:Name="OreBox"
                         Grid.Row="7" Grid.Column="1"
                         Style="{StaticResource GlassTextBox}"
                         Margin="0 4"/>

                <!-- Salario base -->
                <TextBlock Text="Salario base €/h"
                           Grid.Row="8" Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0 4"/>
                <TextBox x:Name="SalarioBaseBox"
                         Grid.Row="8" Grid.Column="1"
                         Style="{StaticResource GlassTextBox}"
                         Margin="0 4"/>

                <!-- Salario extra -->
                <TextBlock Text="Salario extra €/h"
                           Grid.Row="9" Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0 4"/>
                <TextBox x:Name="SalarioExtraBox"
                         Grid.Row="9" Grid.Column="1"
                         Style="{StaticResource GlassTextBox}"
                         Margin="0 4"/>

                <!-- Orario ingresso previsto 1 -->

                <!-- Orario uscita prevista 1 -->

                <!-- Orario ingresso previsto 2 -->

                <!-- Orario uscita prevista 2 -->

                <!-- Pulsanti -->
                <StackPanel Grid.Row="14" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">
                    <Button Content="Salva"
                            Width="100"
                            Margin="5"
                            Style="{StaticResource GlassButton}"
                            Click="Save_Click"/>
                    <Button Content="Annulla"
                            Width="100"
                            Margin="5"
                            Style="{StaticResource GlassButton}"
                            Click="Cancel_Click"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
