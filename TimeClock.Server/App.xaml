<Application x:Class="TimeClock.Server.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>

        <!-- Ombra vetro -->
        <DropShadowEffect x:Key="DropShadowEffect" 
                          BlurRadius="25"
                          ShadowDepth="0"
                          Opacity="0.5"
                          Color="#000000"/>


        <!-- =============== -->
        <!-- GLASS TEXTBOX   -->
        <!-- =============== -->
        <Style x:Key="GlassTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#E6FFFFFF"/>
            <Setter Property="BorderBrush" Value="#60FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>


        <!-- =============== -->
        <!-- GLASS BUTTON    -->
        <!-- =============== -->
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="8 4"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#F0FFFFFF"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="4">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- ================= -->
        <!-- GLASS DATEPICKER  -->
        <!-- ================= -->
        <Style x:Key="GlassDatePicker" TargetType="DatePicker">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#F0FFFFFF"/>
            <Setter Property="BorderBrush" Value="#60FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>


        <!-- ================= -->
        <!-- GLASS CHECKBOX    -->
        <!-- ================= -->
        <Style TargetType="CheckBox" x:Key="GlassCheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>


        <!-- ================= -->
        <!-- GLASS COMBOBOX    -->
        <!-- ================= -->
        <Style x:Key="GlassComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#F0FFFFFF"/>
            <Setter Property="BorderBrush" Value="#60FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="FontSize" Value="16"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- BOX PRINCIPALE -->
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    CornerRadius="6"
                                    BorderThickness="1">
                                <DockPanel>
                                    <ContentPresenter Margin="8"
                                                      VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>

                            <!-- FRECCIA -->
                            <ToggleButton Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Width="20"
                                          Margin="0 0 4 0"
                                          Background="Transparent"
                                          Foreground="Black"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Path Data="M 0 0 L 10 0 L 5 5 Z"
                                      Fill="Black"/>
                            </ToggleButton>

                            <!-- POPUP -->
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   StaysOpen="False">
                                <Border Background="White"
                                        BorderBrush="#60FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- ================= -->
        <!-- GLASS DATAGRID    -->
        <!-- ================= -->
        <Style TargetType="DataGrid" x:Key="GlassDataGrid">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RowBackground" Value="#20FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#10FFFFFF"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <!-- Evidenziare righe festivi nella DataGrid -->
        <Style TargetType="DataGridRow" x:Key="FestiviRowStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#10000000"/>
            <Style.Triggers>

                <!-- Se  festivo: riga rossa vetro -->
                <DataTrigger Binding="{Binding IsFestivo}" Value="True">
                    <Setter Property="Background" Value="#40FF5050"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>

            </Style.Triggers>
        </Style>


    </Application.Resources>

</Application>
