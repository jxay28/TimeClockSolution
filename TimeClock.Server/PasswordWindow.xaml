<Window x:Class="TimeClock.Server.PasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Accesso Protetto" Height="250" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Border Background="#FF0F172A" CornerRadius="15" BorderBrush="#40FFFFFF" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="20" ShadowDepth="5"/>
        </Border.Effect>
        <StackPanel Margin="20" VerticalAlignment="Center">
            <TextBlock Text="Server Protetto" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Inserire prima la password di sblocco" FontSize="14" Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <PasswordBox x:Name="PwdBox" KeyDown="PwdBox_KeyDown" Height="35" FontSize="16" Background="#10FFFFFF" Foreground="White" BorderBrush="#40FFFFFF" Margin="0,0,0,15" Padding="5"/>
            
            <TextBlock x:Name="ErrorText" Text="Password errata" Foreground="#FF4B4B" FontSize="12" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Sblocca" Width="100" Height="35" Margin="0,0,10,0" Background="#2010B981" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Sblocca_Click"/>
                <Button Content="Esci" Width="100" Height="35" Background="#40FF4B4B" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Esci_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
