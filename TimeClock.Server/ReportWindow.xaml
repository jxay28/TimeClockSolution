<Window x:Class="TimeClock.Server.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report Mensile"
        Height="700"
        Width="1400"
        WindowStartupLocation="CenterOwner"
        Background="#FF0F172A"
        WindowStyle="None"
        AllowsTransparency="True">

    
   
    <Grid Margin="20">

        <!-- CARD CENTRALE -->
        <Border Background="#40FFFFFF"
                CornerRadius="18"
                Padding="20"
                Effect="{DynamicResource DropShadowEffect}">

            <DockPanel LastChildFill="True">

                <!-- AREA SUPERIORE (selezioni + pulsanti) -->
                <Grid DockPanel.Dock="Top"
                      Margin="0 0 0 20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Mese"
                               FontSize="16"
                               Foreground="White"
                               Margin="0 0 0 4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Anno"
                               FontSize="16"
                               Foreground="White"
                               Margin="0 0 0 4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="Seleziona utente"
                               FontSize="16"
                               Foreground="Beige"
                               Margin="0 0 0 4"/>

                    <ComboBox x:Name="MonthCombo"
                              Grid.Row="1"
                              Grid.Column="0"
                              Width="150"
                              Height="32"
                              Margin="0 0 20 0" VerticalAlignment="Center" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Gennaio"/>
                        <ComboBoxItem Content="Febbraio"/>
                        <ComboBoxItem Content="Marzo"/>
                        <ComboBoxItem Content="Aprile"/>
                        <ComboBoxItem Content="Maggio"/>
                        <ComboBoxItem Content="Giugno"/>
                        <ComboBoxItem Content="Luglio"/>
                        <ComboBoxItem Content="Agosto"/>
                        <ComboBoxItem Content="Settembre"/>
                        <ComboBoxItem Content="Ottobre"/>
                        <ComboBoxItem Content="Novembre"/>
                        <ComboBoxItem Content="Dicembre"/>
                    </ComboBox>

                    <ComboBox x:Name="YearCombo"
                              Grid.Row="1"
                              Grid.Column="1"
                              Width="110"
                              Height="32"
                              Margin="0 0 20 0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>

                    <ComboBox x:Name="UserCombo"
                              Grid.Row="1"
                              Grid.Column="2"
                              Width="280"
                              Height="32"
                              Text="."
                              DisplayMemberPath="FullName"
                              Margin="0 0 10 0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>

                    <StackPanel Grid.Row="1"
                                Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <CheckBox x:Name="ExportAllCheckBox"
                                  Content="All"
                                  Margin="6 0"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource GlassCheckBox}"/>
                        <Button Content="⭮ Caria"
                                Width="84"
                                Height="32"
                                Margin="1 0"
                                Style="{StaticResource GlassButton}"
                                Click="CaricaReport_Click"
                                FontSize="13"/>
                        <Button Content="⇩ Esporta"
                                Width="88"
                                Height="32"
                                Margin="1 0"
                                Style="{StaticResource GlassButton}"
                                Click="Esporta_Click"
                                FontSize="13"/>
                        <Button Content="Agg.Timbratura"
                                Width="106"
                                Height="32"
                                Margin="1 0"
                                Style="{StaticResource GlassButton}"
                                Click="AggiungiTimbratura_Click"
                                FontSize="13"/>
                        <Button Content="💾 Salva"
                                Width="76"
                                Height="32"
                                Margin="8 0 0 0"
                                Style="{StaticResource GlassButton}"
                                Click="SalvaModifiche_Click"
                                FontSize="13"/>
                        <Button Content="Chiudi"
                                Width="78"
                                Height="32"
                                Margin="1 0 0 0"
                                Style="{StaticResource GlassButton}"
                                Background="#40FF4B4B"
                                Click="Chiudi_Click"
                                FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- TABELLA -->
                <DataGrid x:Name="ReportGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="#10FFFFFF"
                      RowStyle="{StaticResource FestiviRowStyle}"
                      Margin="0"
                      DockPanel.Dock="Top"
                      Height="450"
                      CellEditEnding="ReportGrid_CellEditEnding">


                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Giorno"
                        Binding="{Binding Giorno}"
                        Width="60"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Entrata 1"
                        Binding="{Binding Entrata1}"
                        Width="100"/>

                        <DataGridTextColumn Header="Uscita 1"
                        Binding="{Binding Uscita1}"
                        Width="100"/>

                        <DataGridTextColumn Header="Durata 1"
                        Binding="{Binding Durata1Visual}"
                        Width="90"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Entrata 2"
                        Binding="{Binding Entrata2}"
                        Width="100"/>

                        <DataGridTextColumn Header="Uscita 2"
                        Binding="{Binding Uscita2}"
                        Width="100"/>

                        <DataGridTextColumn Header="Durata 2"
                        Binding="{Binding Durata2Visual}"
                        Width="90"
                        IsReadOnly="True"/>

                        <DataGridCheckBoxColumn Header="Festivo"
                            Binding="{Binding IsFestivo}"
                            Width="70"
                            IsReadOnly="True"/>

                        <DataGridTextColumn Header="Ordinarie"
                        Binding="{Binding OreOrdinarieVisual}"
                        Width="90"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Straord."
                        Binding="{Binding OreStraordinarieVisual}"
                        Width="90"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Ferie"
                        Binding="{Binding OreFerieVisual}"
                        Width="60"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Permesso"
                        Binding="{Binding OrePermessoVisual}"
                        Width="70"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Malattia"
                        Binding="{Binding OreMalattiaVisual}"
                        Width="70"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Note"
                        Binding="{Binding Note}"
                        Width="*"/>
                    </DataGrid.Columns>


                </DataGrid>

                <!-- TOTALI -->
                <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 15 0 0">

                    <Border Background="#30FFFFFF" Padding="1" CornerRadius="10" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Totale ore ordinarie:" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="TotOrdinarieText" Foreground="Beige" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#30FFFFFF" Padding="1" CornerRadius="10" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Totale ore straordinarie:" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="TotStraordinarieText" Foreground="Beige" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#30FFFFFF" Padding="1" CornerRadius="10" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Totale ferie usate:" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="TotFerieText" Foreground="Beige" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="#30FFFFFF" Padding="1" CornerRadius="10" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Tot. permessi:" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="TotPermessoText" Foreground="Beige" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="#30FFFFFF" Padding="1" CornerRadius="10" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Tot. malattie:" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="TotMalattiaText" Foreground="Beige" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                </StackPanel>


            </DockPanel>


        </Border>

    </Grid>

</Window>
