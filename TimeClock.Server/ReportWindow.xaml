<Window x:Class="TimeClock.Server.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report Mensile"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#FF0F172A"
        WindowStyle="None"
        AllowsTransparency="True">

    <Grid Margin="20">

        <Border Background="#40FFFFFF"
                CornerRadius="18"
                Padding="20">

            <DockPanel LastChildFill="True">

                <!-- HEADER SUPERIORE -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0 0 0 20"
                            VerticalAlignment="Top">

                    <!-- MESE -->
                    <StackPanel Orientation="Vertical" Margin="0 0 20 0">
                        <TextBlock Text="Mese"
                                   FontSize="16"
                                   Foreground="White"/>
                        <ComboBox x:Name="MonthCombo"
                                  Width="150"
                                  Margin="0 5">
                            <ComboBoxItem Content="Gennaio"/>
                            <ComboBoxItem Content="Febbraio"/>
                            <ComboBoxItem Content="Marzo"/>
                            <ComboBoxItem Content="Aprile"/>
                            <ComboBoxItem Content="Maggio"/>
                            <ComboBoxItem Content="Giugno"/>
                            <ComboBoxItem Content="Luglio"/>
                            <ComboBoxItem Content="Agosto"/>
                            <ComboBoxItem Content="Settembre"/>
                            <ComboBoxItem Content="Ottobre"/>
                            <ComboBoxItem Content="Novembre"/>
                            <ComboBoxItem Content="Dicembre"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- UTENTE -->
                    <StackPanel Orientation="Vertical" Margin="0 0 20 0">
                        <TextBlock Text="Utente"
                                   FontSize="16"
                                   Foreground="White"/>
                        <ComboBox x:Name="UserCombo"
                                  Width="300"
                                  Margin="0 5"
                                  DisplayMemberPath="FullName"/>
                    </StackPanel>

                    <!-- PULSANTI -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Bottom">

                        <Button Content="Carica Report"
                                Width="140"
                                Margin="10 0"
                                Click="CaricaReport_Click"/>

                        <Button Content="Ricalcola"
                                Width="120"
                                Margin="10 0"
                                Click="RicalcolaReport_Click"/>

                        <Button Content="Aggiungi Timbratura"
                                Width="150"
                                Margin="10 0"
                                Click="AggiungiTimbratura_Click"/>

                        <Button Content="Salva Modifiche"
                                Width="150"
                                Margin="10 0"
                                Click="SalvaModifiche_Click"/>

                        <Button Content="Esporta TXT"
                                Width="120"
                                Margin="10 0"
                                Click="EsportaTXT_Click"/>

                        <Button Content="Esporta PDF"
                                Width="120"
                                Margin="10 0"
                                Click="EsportaPDF_Click"/>
                    </StackPanel>

                </StackPanel>

                <!-- DATAGRID -->
                <DataGrid x:Name="ReportGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="#10FFFFFF"
                          Foreground="White"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#30FFFFFF"
                          BorderBrush="#50FFFFFF"
                          BorderThickness="1">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Giorno"
                                            Binding="{Binding Giorno}"
                                            Width="60"
                                            IsReadOnly="True"/>

                        <DataGridTextColumn Header="Entrata"
                                            Binding="{Binding Entrata}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Uscita"
                                            Binding="{Binding Uscita}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Ordinarie"
                                            Binding="{Binding OreOrdinarie}"
                                            Width="100"
                                            IsReadOnly="True"/>

                        <DataGridTextColumn Header="Extra"
                                            Binding="{Binding OreStraordinarie}"
                                            Width="100"
                                            IsReadOnly="True"/>

                        <DataGridCheckBoxColumn Header="Festivo"
                                                Binding="{Binding IsFestivo}"
                                                Width="80"
                                                IsReadOnly="True"/>

                        <DataGridTextColumn Header="Note"
                                            Binding="{Binding Note}"
                                            Width="*"/>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- FOOTER TOTALI -->
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0 15 0 0">

                    <TextBlock Text="Tot. Ordinarie:"
                               Foreground="White"
                               Margin="0 0 10 0"/>
                    <TextBlock x:Name="TotOrdinarieText"
                               Foreground="White"
                               Width="80"/>

                    <TextBlock Text="Tot. Extra:"
                               Foreground="White"
                               Margin="30 0 10 0"/>
                    <TextBlock x:Name="TotStraordinarieText"
                               Foreground="White"
                               Width="80"/>

                </StackPanel>

            </DockPanel>

        </Border>

    </Grid>

</Window>
