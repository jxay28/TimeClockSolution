<Window x:Class="TimeClock.Server.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report Mensile"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="#FF0F172A"
        WindowStyle="None"
        AllowsTransparency="True">

    
   
    <Grid Margin="20">

        <!-- CARD CENTRALE -->
        <Border Background="#40FFFFFF"
                CornerRadius="18"
                Padding="20"
                Effect="{DynamicResource DropShadowEffect}">

            <DockPanel LastChildFill="True">

                <!-- AREA SUPERIORE (selezioni + pulsanti) -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0 0 0 20"
                            VerticalAlignment="Center">

                    <!-- MESE -->
                    <StackPanel Orientation="Vertical" Margin="0 0 20 0">
                        <TextBlock Text="Mese"
                                   FontSize="16"
                                   Foreground="White"/>
                        <ComboBox x:Name="MonthCombo"
                                  Width="150"
                                  Margin="0 5">
                            <ComboBoxItem Content="Gennaio"/>
                            <ComboBoxItem Content="Febbraio"/>
                            <ComboBoxItem Content="Marzo"/>
                            <ComboBoxItem Content="Aprile"/>
                            <ComboBoxItem Content="Maggio"/>
                            <ComboBoxItem Content="Giugno"/>
                            <ComboBoxItem Content="Luglio"/>
                            <ComboBoxItem Content="Agosto"/>
                            <ComboBoxItem Content="Settembre"/>
                            <ComboBoxItem Content="Ottobre"/>
                            <ComboBoxItem Content="Novembre"/>
                            <ComboBoxItem Content="Dicembre"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- UTENTE -->
                    <StackPanel Orientation="Vertical" Margin="0 0 5 0" Width="200">
                        <TextBlock Text="Seleziona utente"
                                   FontSize="16"
                                   Foreground="Beige"/>
                        <ComboBox x:Name="UserCombo"
                                  Width="280"
                                  
                                  
                                  
                                  Text="."
                                  DisplayMemberPath="FullName"
                                  Margin="0 5"/>
                    </StackPanel>

                    <!-- PULSANTI -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        
                        


                        <Button Content="Carica Report"
                                Width="100"
                                
                                Margin="1 0"
                                Style="{StaticResource GlassButton}"
                                Click="CaricaReport_Click" RenderTransformOrigin="0.5,0.5" FontSize="12">
                            <Button.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                   
                                </TransformGroup>
                            </Button.RenderTransform>
                        </Button>

                        

                        <Button Content="Esporta PDF"
                                Width="100"
                                Margin="1 0"
                                Style="{StaticResource GlassButton}"
                                Click="EsportaPDF_Click"/>

                        <Button Content="Esporta TXT"
                                Width="100"
                                Margin="1 0"
                                Style="{StaticResource GlassButton}"
                                Click="EsportaTXT_Click"/>
                        <Button Content="Salva Modifiche"
                                Width="100"
                                Margin="1 0"
                                Style="{StaticResource GlassButton}"
                                Click="SalvaModifiche_Click" FontSize="12"/>
                        <Button Content="Aggiungi Timbratura"
                                Width="120"
                                Margin="1 0"
                                Style="{StaticResource GlassButton}"
                                Click="AggiungiTimbratura_Click" FontSize="12"/>
                        <Button Content="Chiudi"
                                Width="90"
                                Margin="20 0 0 0" 
                                Style="{StaticResource GlassButton}"
                                Background="#40FF4B4B"
                                Click="Chiudi_Click"/>
                        



                    </StackPanel>
                </StackPanel>

                <!-- TABELLA -->
                <DataGrid x:Name="ReportGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="#10FFFFFF"
                      RowStyle="{StaticResource FestiviRowStyle}"
                      Margin="0"
                      DockPanel.Dock="Top"
                      Height="450"
                      CellEditEnding="ReportGrid_CellEditEnding">


                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Giorno"
                        Binding="{Binding Giorno}"
                        Width="60"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Entrata 1"
                        Binding="{Binding Entrata1}"
                        Width="100"/>

                        <DataGridTextColumn Header="Uscita 1"
                        Binding="{Binding Uscita1}"
                        Width="100"/>

                        <DataGridTextColumn Header="Durata 1"
                        Binding="{Binding Durata1Visual}"
                        Width="90"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Entrata 2"
                        Binding="{Binding Entrata2}"
                        Width="100"/>

                        <DataGridTextColumn Header="Uscita 2"
                        Binding="{Binding Uscita2}"
                        Width="100"/>

                        <DataGridTextColumn Header="Durata 2"
                        Binding="{Binding Durata2Visual}"
                        Width="90"
                        IsReadOnly="True"/>

                        <DataGridCheckBoxColumn Header="Festivo"
                            Binding="{Binding IsFestivo}"
                            Width="70"
                            IsReadOnly="True"/>

                        <DataGridTextColumn Header="Ordinarie"
                        Binding="{Binding OreOrdinarieVisual}"
                        Width="90"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Straord."
                        Binding="{Binding OreStraordinarieVisual}"
                        Width="90"
                        IsReadOnly="True"/>

                        <DataGridTextColumn Header="Note"
                        Binding="{Binding Note}"
                        Width="*"/>
                    </DataGrid.Columns>


                </DataGrid>

                <!-- TOTALI -->
                <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 15 0 0">

                    <Border Background="#30FFFFFF" Padding="1" CornerRadius="10" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Totale ore ordinarie:" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="TotOrdinarieText" Foreground="Beige" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#30FFFFFF" Padding="1" CornerRadius="10" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Totale ore straordinarie:" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="TotStraordinarieText" Foreground="Beige" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                </StackPanel>


            </DockPanel>


        </Border>

    </Grid>

</Window>
