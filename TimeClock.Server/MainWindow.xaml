<Window x:Class="TimeClock.Server.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Height="650" Width="1100"
        Title="TimeClock Server">

    <Window.Resources>
        <DropShadowEffect x:Key="DropShadow"
                          Color="Black"
                          Opacity="0.45"
                          BlurRadius="30"
                          ShadowDepth="5"/>

        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#20FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="AddButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Background" Value="#4010B981"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FF0F172A" SnapsToDevicePixels="True">

        <!-- SFONDO -->

        <!-- PANNELLO GLASS -->
        <Border Margin="30"
                CornerRadius="25"
                Background="#40FFFFFF"
                Effect="{DynamicResource DropShadow}">

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER SUPERIORE -->
                <DockPanel Grid.Row="0">
                    <TextBlock Text="TimeClock Server"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               DockPanel.Dock="Left"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="_"
                                Width="28" Height="24"
                                Margin="4"
                                Click="Min_Click"
                                Background="#20FFFFFF"
                                Foreground="White"/>
                        <Button Content="X"
                                Width="28" Height="24"
                                Margin="4"
                                Click="Close_Click"
                                Background="#40FF4B4B"
                                Foreground="White"/>
                    </StackPanel>
                </DockPanel>

                <!-- CONTENUTO PRINCIPALE -->
                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                          
                        

                    </Grid.ColumnDefinitions>

                    <!-- MENU LATERALE -->
                    <StackPanel Grid.Column="0"
                                Background="#20FFFFFF"
                                Margin="0,0,20,0"
                                >
                        <TextBlock Text="Menu"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,0,10"/>

                        <Button Content="Anagrafica utenti"
                                Style="{StaticResource GlassButton}"
                                Tag="0"
                                Click="Menu_Click"/>
                        <Button Content="Festivit&#224;"
                                Style="{StaticResource GlassButton}"
                                Tag="1"
                                Click="Menu_Click"/>
                        <Button Content="Parametri straordinari"
                                Style="{StaticResource GlassButton}"
                                Tag="2"
                                Click="Menu_Click"/>
                        <Button Content="Report"
                                Style="{StaticResource GlassButton}"
                                Tag="3"
                                Click="Menu_Click"/>
                        <Button Content="Opzioni"
                                Style="{StaticResource GlassButton}"
                                Tag="4"
                                Click="Menu_Click"/>

                    </StackPanel>

                    <!-- SEZIONE CONTENUTI -->
                    <Border Grid.Column="1"
                            Background="#30FFFFFF"
                            CornerRadius="20">

                        <TabControl x:Name="MainTabs"
                                    Background="Transparent"
                                    BorderThickness="0" Cursor="">

                            <!-- ANAGRAFICA -->
                            <TabItem Header="Anagrafica utenti" IsSelected="True" VerticalAlignment="Bottom">
                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Button Content="Aggiungi utente"
                                            Style="{StaticResource AddButton}"
                                            Width="170"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,15"
                                            Click="AddUser_Click"/>

                                    <DataGrid x:Name="UsersGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              Background="#15FFFFFF"
                                              Foreground="Black"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              BorderBrush="#40FFFFFF"
                                              BorderThickness="1"
                                              RowHeight="32">

                                        <DataGrid.Columns>

                                            <DataGridTextColumn Header="N"
                                                                Binding="{Binding SequenceNumber}" />

                                            <DataGridTextColumn Header="ID"
                                                                Binding="{Binding Id}" />

                                            <DataGridTextColumn Header="Nome"
                                                                Binding="{Binding Nome}" />

                                            <DataGridTextColumn Header="Cognome"
                                                                Binding="{Binding Cognome}" />

                                            <DataGridTextColumn Header="Ruolo"
                                                                Binding="{Binding Ruolo}" />

                                            <DataGridTextColumn Header="Data Assunzione"
                                                                Binding="{Binding DataAssunzione, StringFormat=\{0:dd/MM/yyyy\}}" />

                                            <DataGridTextColumn Header="Ore Sett."
                                                                Binding="{Binding OreContrattoSettimanali}" />

                                            <DataGridTextColumn Header="Compenso Base"
                                                                Binding="{Binding CompensoOrarioBase}" />

                                            <DataGridTextColumn Header="Compenso Extra"
                                                                Binding="{Binding CompensoOrarioExtra}" />

                                        </DataGrid.Columns>

                                    </DataGrid>
                                </Grid>
                            </TabItem>


                            <TabItem Header="Festivit&#224;" Visibility="Visible">
                                <Grid Margin="20">
                                    <Button Content="Aggiungi giorno festivo"
                                            Style="{StaticResource AddButton}"
                                            Width="220"
                                            Margin="0,0,0,15"
                                            Click="AddHoliday_Click"/>

                                    <DataGrid x:Name="HolidayGrid"
                                              AutoGenerateColumns="True"
                                              Background="#15FFFFFF"
                                              Foreground="White"/>
                                </Grid>
                            </TabItem>

                            <!-- STRAORDINARI -->
                            <TabItem Header="Parametri straordinari">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid Margin="20">

                                        <!-- CARD VETRO -->
                                        <Border Background="#40FFFFFF"
                    CornerRadius="18"
                    Padding="25"
                    Effect="{DynamicResource DropShadowEffect}">

                                            <StackPanel Orientation="Vertical"
                            VerticalAlignment="Top"
                            Margin="10">

                                                <!-- SOGLIA MINUTI -->
                                                <TextBlock Text="Intervallo di arrotondamento"
                               FontSize="18"
                               Foreground="White"
                               Margin="0 0 0 10"/>

                                                <Slider x:Name="OvertimeSlider"
                            Minimum="5"
                            Maximum="120"
                            Value="15"
                            TickFrequency="5"
                            IsSnapToTickEnabled="True"
                            Margin="0,10"/>

                                                <TextBlock Text="Valore attuale:"
                               Foreground="White"
                               FontSize="14"/>

                                                <TextBlock x:Name="OvertimeValue"
                               Text="15 minuti"
                               FontSize="26"
                               Foreground="#FFD4D4"/>

                                                <Separator Margin="0 20"/>


                                                <!-- ORARI PREVISTI DELLANAGRAFICA -->


                                                <!-- FESTIVIT NAZIONALI -->
                                                <TextBlock Text="Festivit nazionali"
                               FontSize="18"
                               Foreground="White"
                               Margin="0 0 0 10"/>

                                                <StackPanel Orientation="Vertical">

                                                    <CheckBox Content="1 gennaio - Capodanno" Foreground="White"/>
                                                    <CheckBox Content="6 gennaio - Epifania" Foreground="White"/>
                                                    <CheckBox Content="Pasqua" Foreground="White"/>
                                                    <CheckBox Content="Luned dell'Angelo" Foreground="White"/>
                                                    <CheckBox Content="25 aprile - Liberazione" Foreground="White"/>
                                                    <CheckBox Content="1 maggio - Festa dei lavoratori" Foreground="White"/>
                                                    <CheckBox Content="2 giugno - Festa della Repubblica" Foreground="White"/>
                                                    <CheckBox Content="15 agosto - Ferragosto" Foreground="White"/>
                                                    <CheckBox Content="1 novembre - Ognissanti" Foreground="White"/>
                                                    <CheckBox Content="8 dicembre - Immacolata Concezione" Foreground="White"/>
                                                    <CheckBox Content="25 dicembre - Natale" Foreground="White"/>
                                                    <CheckBox Content="26 dicembre - Santo Stefano" Foreground="White"/>

                                                </StackPanel>

                                                <Separator Margin="0 20"/>


                                                <!-- WEEKEND -->
                                                <TextBlock Text="Weekend"
                               FontSize="18"
                               Foreground="White"
                               Margin="0 0 0 10"/>

                                                <CheckBox x:Name="SaturdayCheck"
                              Content="Sabato considerato straordinario"
                              Foreground="White"/>

                                                <CheckBox x:Name="SundayCheck"
                              Content="Domenica considerata straordinario"
                              Foreground="White"/>

                                                <Separator Margin="0 20"/>


                                                <!-- FESTIVIT PERSONALIZZATE -->
                                                <TextBlock Text="Festivit personalizzate"
                               FontSize="18"
                               Foreground="White"
                               Margin="0 0 0 10"/>

                                                <StackPanel Orientation="Horizontal" Margin="0 5">
                                                    <DatePicker x:Name="CustomHolidayPicker"
                                    Width="150"/>
                                                    <Button x:Name="AddCustomHolidayButton"
                                Content="Aggiungi"
                                Width="120"
                                Margin="20 0"
                                Style="{StaticResource GlassButton}"/>
                                                </StackPanel>

                                                <ItemsControl x:Name="CustomHolidayList"
                                  Margin="0 10">
                                                    <!-- Righe aggiunte da codice:
                             Es: "15/02/2025    [Rimuovi]" -->
                                                </ItemsControl>


                                                <Separator Margin="0 20"/>

                                                <!-- PULSANTI FINALI -->
                                                <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">

                                                    <Button x:Name="SaveOvertimeParamsButton"
                                Content="Salva parametri"
                                Width="150"
                                Margin="5"
                                Style="{StaticResource GlassButton}"/>

                                                    <Button x:Name="CancelOvertimeParamsButton"
                                Content="Annulla"
                                Width="120"
                                Margin="5"
                                Style="{StaticResource GlassButton}"/>

                                                </StackPanel>

                                            </StackPanel>

                                        </Border>

                                    </Grid>
                                </ScrollViewer>
                            </TabItem>
                            <!-- REPORT -->
                            <TabItem Header="Report">
                                <StackPanel Margin="20">
                                    <Button Content="Genera report mensili"
                                            Style="{StaticResource AddButton}"
                                            Width="200"
                                            Click="GenerateReport_Click" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </TabItem>

                            <!-- CARTELLA -->
                            <TabItem Header="Opzioni">
                                <StackPanel Margin="20">
                                    <TextBlock Text="Percorso cartella condivisa:"
                                               Foreground="White"/>

                                    <TextBox x:Name="CsvPathBox"
                                             Margin="0,10"
                                             Background="#10FFFFFF"
                                             Foreground="White"
                                             BorderBrush="#40FFFFFF"/>

                                    <Button Content="Scegli cartella"
                                            Style="{StaticResource GlassButton}"
                                            Width="150"
                                            Click="SelectCsvFolder_Click"/>
                                </StackPanel>
                            </TabItem>

                        </TabControl>

                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Grid>

</Window>
